# Docker Compose production example

POSTGRES_DB=hospital_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password

JWT_SECRET=change-me-jwt-secret

# Local first-install default.
# If staff will open the system from another machine, replace localhost with the server IP/hostname.
FRONTEND_URLS=http://localhost:8080,http://127.0.0.1:8080

# First administrator created on initial start
BOOTSTRAP_ADMIN_EMAIL=admin@hospital.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Optional published ports
POSTGRES_PORT=5432
BACKEND_PORT=3001
FRONTEND_PORT=8080

# Optional runtime tuning
AUTH_COOKIE_SECURE=auto
TRUST_PROXY=false
MAX_FILE_SIZE=52428800
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hospital_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
AUTH_COOKIE_NAME="hospital_auth"
AUTH_COOKIE_SECURE="auto"
AUTH_COOKIE_MAX_AGE_MS=604800000

# Server
PORT=3001
NODE_ENV=development
TRUST_PROXY=false

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Frontend URLs (comma-separated, for CORS / Socket.IO)
FRONTEND_URLS=http://localhost:5173

# Logging
LOG_DIR=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Bootstrap admin for first production launch
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Demo seed data (enable only for local development)
SEED_DEMO_DATA=true
